{
  "name": "@ory-cms/cli",
  "version": "0.1.5",
  "description": "OryCMS command-line interface — initialise, configure, migrate, and seed OryCMS in any Next.js project",
  "type": "module",
  "bin": {
    "orycms": "dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck && npm run test"
  },
  "keywords": [
    "orycms",
    "cli",
    "cms",
    "nextjs",
    "headless-cms",
    "content-management"
  ],
  "author": "OrynticLabs Private Limited <support@orynticlabs.com>",
  "license": "MIT",
  "homepage": "https://github.com/orynticlabs/orycms#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orynticlabs/orycms.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/orynticlabs/orycms/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
