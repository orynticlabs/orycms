{
  "name": "@ory-cms/next",
  "version": "0.1.3",
  "description": "OryCMS Next.js first-run setup, login, and admin dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "keywords": [
    "orycms",
    "cms",
    "headless-cms",
    "nextjs",
    "react",
    "ui",
    "admin",
    "shadcn",
    "radix-ui"
  ],
  "author": "OrynticLabs <support@orynticlabs.com>",
  "license": "MIT",
  "homepage": "https://github.com/orynticlabs/orycms#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orynticlabs/orycms.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/orynticlabs/orycms/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@ory-cms/core": "^0.1.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
